# PostgreSQL connection (Supabase / Neon / Railway etc.)
DATABASE_URL="postgresql://user:password@host:port/dbname?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:port/dbname"

# Strong random secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace_with_strong_random_secret"

# Your deployed frontend URL (set this on Render)
CLIENT_URL="https://your-frontend.vercel.app"

# Port — Render sets this automatically, don't override on Render
PORT=5000

# Redis connection (Upstash / local)
REDIS_URL="redis://localhost:6379"

# Cron job secret — protects /reports/prepare-monthly endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="replace_with_strong_random_secret"

# SMTP settings for sending report emails (Gmail SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
