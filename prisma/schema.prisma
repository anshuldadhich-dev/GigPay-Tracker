// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider             = "prisma-client"
  output               = "../generated/prisma-client-ts"
  moduleFormat         = "cjs"
  importFileExtension  = "js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  password     String?
  authProvider String     @default("local") @map("auth_provider")
  phone        String?
  city         String?
  profilePhoto String?    @map("profile_photo")
  goalDaily    Float      @default(1500) @map("goal_daily")
  goalWeekly   Float      @default(8000) @map("goal_weekly")
  goalMonthly  Float      @default(30000) @map("goal_monthly")
  createdAt    DateTime   @default(now()) @map("created_at")
  rides        Ride[]
  fuelLogs     FuelLog[]
  shifts       Shift[]

  @@map("users")
}

model Ride {
  id        Int      @id @default(autoincrement())
  pickup    String
  dropoff   String   @map("dropoff")
  fare      Float
  platform  String?
  createdAt DateTime @default(now()) @map("created_at")
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  @@map("rides")
}

model FuelLog {
  id            Int      @id @default(autoincrement())
  date          DateTime
  liters        Float
  pricePerLiter Float    @map("price_per_liter")
  totalCost     Float    @map("total_cost")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  userId        Int      @map("user_id")
  user          User     @relation(fields: [userId], references: [id])

  @@map("fuel_logs")
}

model Shift {
  id                 Int       @id @default(autoincrement())
  userId             Int       @map("user_id")
  date               DateTime
  startTime          DateTime  @map("start_time")
  endTime            DateTime? @map("end_time")
  startOdometer      Float?    @map("start_odometer")
  endOdometer        Float?    @map("end_odometer")
  totalHours         Float?    @map("total_hours")
  totalDistance      Float?    @map("total_distance")
  totalEarnings      Float?    @map("total_earnings")
  fuelCost           Float?    @map("fuel_cost")
  profit             Float?    @map("profit")
  status             String    @default("ACTIVE") @map("status")
  platforms          String?   @map("platforms")
  pausedAt           DateTime? @map("paused_at")
  totalPausedMinutes Float     @default(0) @map("total_paused_minutes")
  autoEnded          Boolean   @default(false) @map("auto_ended")
  createdAt          DateTime  @default(now()) @map("created_at")
  user               User      @relation(fields: [userId], references: [id])

  @@map("shifts")
}
