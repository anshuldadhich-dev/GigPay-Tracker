{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node10",
    "outDir": "./generated/prisma-client",
    "rootDir": "./generated/prisma-client-ts",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "declaration": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["./generated/prisma-client-ts/**/*.ts"]
}
